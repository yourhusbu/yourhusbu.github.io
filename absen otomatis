<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sistem Rekap Absensi</title>
  
  <!-- Memuat Library React, Babel (untuk membaca JSX), dan Tailwind CSS (untuk Tampilan) -->
  <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <div id="root"></div>

  <!-- Script Utama Aplikasi -->
  <script type="text/babel">
    const { useState, useMemo } = React;

    // --- ICONS (Mengganti Lucide dengan inline SVG agar tidak perlu koneksi library icon) ---
    const IconCalculator = ({size=18, className=""}) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><line x1="8" y1="6" x2="16" y2="6"></line><line x1="16" y1="14" x2="16" y2="18"></line><path d="M16 10h.01"></path><path d="M12 10h.01"></path><path d="M8 10h.01"></path><path d="M12 14h.01"></path><path d="M8 14h.01"></path><path d="M12 18h.01"></path><path d="M8 18h.01"></path></svg>;
    const IconPlus = ({size=18, className=""}) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>;
    const IconTrash2 = ({size=18, className=""}) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>;
    const IconFileText = ({size=18, className=""}) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>;
    const IconUpload = ({size=18, className=""}) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>;
    const IconAlertCircle = ({size=18, className=""}) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>;
    const IconClipboardList = ({size=18, className=""}) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path><path d="M12 11h4"></path><path d="M12 16h4"></path><path d="M8 11h.01"></path><path d="M8 16h.01"></path></svg>;
    const IconUsers = ({size=18, className=""}) => <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>;

    // --- HELPER FUNCTIONS ---
    const parseTime = (timeStr) => {
      if (!timeStr) return null;
      const [h, m] = timeStr.split(':').map(Number);
      return h * 60 + m; 
    };

    const formatTime = (minutes) => {
      if (minutes === null || isNaN(minutes)) return '-';
      const h = Math.floor(minutes / 60);
      const m = minutes % 60;
      return `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}`;
    };

    // --- MAIN APP COMPONENT ---
    function App() {
      const [activeTab, setActiveTab] = useState('harian');
      const [rawText, setRawText] = useState('');
      const [replaceData, setReplaceData] = useState(true);
      const [importMessage, setImportMessage] = useState('');
      
      const [records, setRecords] = useState([
        { id: 1, date: '2026-05-01', name: 'Si A', inNormal: '08:10', outNormal: '19:00', inLembur: '', outLembur: '' },
        { id: 2, date: '2026-05-01', name: 'Si B', inNormal: '08:29', outNormal: '16:50', inLembur: '18:00', outLembur: '22:00' },
        { id: 3, date: '2026-05-02', name: 'Si C', inNormal: '08:10', outNormal: '12:00', inLembur: '', outLembur: '' },
        { id: 4, date: '2026-05-02', name: 'Si D', inNormal: '13:00', outNormal: '16:50', inLembur: '', outLembur: '' },
      ]);

      const [formData, setFormData] = useState({
        date: new Date().toISOString().split('T')[0],
        name: '',
        inNormal: '',
        outNormal: '',
        inLembur: '',
        outLembur: ''
      });

      // --- LOGIC: IMPORT & PARSER ---
      const handleFileUpload = (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (event) => {
          setRawText(event.target.result);
        };
        reader.readAsText(file);
      };

      const processImport = () => {
        setImportMessage('');
        if (!rawText.trim()) {
          setImportMessage("Error: Data masih kosong!");
          return;
        }

        const normalized = rawText.replace(/["',]/g, ' ');
        const tokens = normalized.split(/\s+/);
        const ignoreWords = new Set(['IN', 'OUT', 'MASUK', 'KELUAR', 'PULANG', 'ON', 'OFF', 'JARI', 'PIN', 'FACE', 'WAJAH', 'FINGER', 'SCAN', 'TIPE', 'MODE', 'WAKTU', 'TANGGAL', 'MESIN', 'ID', 'NAMA', 'NO']);
        
        const extracted = [];

        for (let i = 0; i < tokens.length; i++) {
          const token = tokens[i];
          if (/^\d{4}[-/]\d{2}[-/]\d{2}$/.test(token) && i + 1 < tokens.length) {
            const timeToken = tokens[i + 1];
            if (/^\d{2}:\d{2}(:\d{2})?$/.test(timeToken)) {
              const time = timeToken.substring(0, 5); 
              const date = token.replace(/\//g, '-'); 
              
              let name = "UNKNOWN";
              let nameTokens = [];
              
              for (let j = i - 1; j >= 0; j--) {
                const prev = tokens[j].toUpperCase();
                if (/^\d+$/.test(prev)) continue; 
                if (ignoreWords.has(prev)) continue; 
                if (/^[A-Z]+$/.test(prev)) {
                  nameTokens.unshift(tokens[j]); 
                  const prev2 = j > 0 ? tokens[j-1].toUpperCase() : '';
                  if (!/^[A-Z]+$/.test(prev2) || ignoreWords.has(prev2)) {
                     break; 
                  }
                }
              }
              if (nameTokens.length > 0) name = nameTokens.join(' ');
              
              extracted.push({ name, date, time });
              i++; 
            }
          }
        }

        const groups = {};
        extracted.forEach(item => {
          const key = `${item.name}_${item.date}`;
          if (!groups[key]) groups[key] = { name: item.name, date: item.date, times: [] };
          if (!groups[key].times.includes(item.time)) groups[key].times.push(item.time);
        });

        const newRecords = [];
        Object.values(groups).forEach((group, index) => {
          group.times.sort(); 
          const taps = group.times;
          let inN = '', outN = '', inL = '', outL = '';
          
          if (taps.length === 1) {
            inN = taps[0];
          } else if (taps.length === 2) {
            inN = taps[0];
            outN = taps[1];
          } else if (taps.length === 3) {
            inN = taps[0];
            outN = taps[1];
            inL = taps[2];
          } else if (taps.length >= 4) {
            inN = taps[0];
            outN = taps[1];
            inL = taps[2];
            outL = taps[taps.length - 1]; 
          }
          
          newRecords.push({
            id: `import-${Date.now()}-${index}`,
            date: group.date,
            name: group.name,
            inNormal: inN,
            outNormal: outN,
            inLembur: inL,
            outLembur: outL
          });
        });

        if (newRecords.length === 0) {
          setImportMessage("Error: Tidak ada data absensi valid yang ditemukan! Pastikan format mengandung Tanggal (YYYY/MM/DD) dan Jam.");
          return;
        }

        if (replaceData) {
          setRecords(newRecords);
        } else {
          setRecords([...records, ...newRecords]);
        }
        
        setActiveTab('harian');
        setRawText('');
      };

      // --- LOGIC: COMPUTE DAILY RECORD ---
      const computeRecord = (record) => {
        const inN = parseTime(record.inNormal);
        const outN = parseTime(record.outNormal);
        const inL = parseTime(record.inLembur);
        const outL = parseTime(record.outLembur);

        let lateMins = 0;
        let hk = 0;
        let otHours = 0;

        // 1. Calculate HK First
        if (inN !== null) {
          hk = 1; // Default Full Day
          
          // Half day rules
          if (outN !== null && outN <= parseTime("12:30")) {
            hk = 0.5; // Morning only
          } else if (inN >= parseTime("12:30")) {
            hk = 0.5; // Afternoon only
          }
        }

        // 2. Calculate Late (ONLY if Full Day / hk === 1)
        if (hk === 1 && inN !== null) {
          let thresholdIn = parseTime("08:10");

          // Pengecualian khusus untuk Nengah (Batas masuk 09:10)
          if (record.name && record.name.toUpperCase().includes('NENGAH')) {
            thresholdIn = parseTime("09:10");
          }
          
          // Aturan khusus: Masuk jam 12:00 - 12:29 dihitung 1 HK, batas telat dihitung dari jam 12:00
          if (inN >= parseTime("11:30") && inN < parseTime("12:30")) {
            thresholdIn = parseTime("12:00");
          }
          
          if (inN > thresholdIn) {
            lateMins = inN - thresholdIn;
          }
        }

        // 3. Calculate Overtime (Lembur Lanjut)
        if (outN !== null) {
          const thresholdOt = parseTime("16:50");
          if (outN > thresholdOt) {
            otHours += Math.round((outN - thresholdOt) / 60);
          }
        }

        // 4. Calculate Overtime (Lembur Putus)
        if (inL !== null && outL !== null) {
          if (outL > inL) {
            otHours += Math.round((outL - inL) / 60);
          } else {
            // Across midnight (e.g., 22:00 to 02:00)
            otHours += Math.round(((outL + 24 * 60) - inL) / 60);
          }
        }

        return { ...record, lateMins, hk, otHours };
      };

      const computedRecords = useMemo(() => records.map(computeRecord), [records]);

      // --- LOGIC: COMPUTE SUMMARY (REKAP 15 HARI) ---
      const summary = useMemo(() => {
        const sum = {};
        computedRecords.forEach(rec => {
          if (!sum[rec.name]) {
            sum[rec.name] = { name: rec.name, hk: 0, ot: 0, late: 0, daysPresent: 0 };
          }
          sum[rec.name].hk += rec.hk;
          sum[rec.name].ot += rec.otHours;
          sum[rec.name].late += rec.lateMins;
          sum[rec.name].daysPresent += 1;
        });

        return Object.values(sum).sort((a, b) => a.name.localeCompare(b.name));
      }, [computedRecords]);

      // --- HANDLERS ---
      const handleAddRecord = (e) => {
        e.preventDefault();
        if (!formData.name || !formData.date || !formData.inNormal) return;
        
        setRecords([...records, { ...formData, id: `manual-${Date.now()}-${Math.random()}` }]);
        setFormData({ ...formData, name: '', inNormal: '', outNormal: '', inLembur: '', outLembur: '' }); 
      };

      const handleDelete = (id) => {
        setRecords(records.filter(r => r.id !== id));
      };

      return (
        <div className="min-h-screen p-4 md:p-8 font-sans text-gray-800">
          <div className="max-w-6xl mx-auto space-y-6">
            
            {/* Header */}
            <div className="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
              <div>
                <h1 className="text-2xl font-bold text-gray-900 flex items-center gap-2">
                  <IconCalculator className="text-blue-600" />
                  Sistem Rekap Absensi
                </h1>
                <p className="text-gray-500 text-sm mt-1">Otomatisasi Hitung Telat, HK, dan Lembur per 15 Hari</p>
              </div>
              <div className="flex gap-2 bg-gray-100 p-1 rounded-lg">
                <button 
                  onClick={() => setActiveTab('harian')}
                  className={`px-4 py-2 rounded-md text-sm font-medium transition-colors ${activeTab === 'harian' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-600 hover:text-gray-900'}`}
                >
                  Data Harian
                </button>
                <button 
                  onClick={() => setActiveTab('import')}
                  className={`px-4 py-2 rounded-md text-sm font-medium transition-colors ${activeTab === 'import' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-600 hover:text-gray-900'}`}
                >
                  Import Otomatis
                </button>
                <button 
                  onClick={() => setActiveTab('rekap')}
                  className={`px-4 py-2 rounded-md text-sm font-medium transition-colors ${activeTab === 'rekap' ? 'bg-white text-blue-600 shadow-sm' : 'text-gray-600 hover:text-gray-900'}`}
                >
                  Rekap Absensi
                </button>
              </div>
            </div>

            {/* --- TAB: IMPORT OTOMATIS --- */}
            {activeTab === 'import' && (
              <div className="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 max-w-2xl">
                <h2 className="text-lg font-semibold mb-2 flex items-center gap-2">
                  <IconUpload size={18} /> Import Data Absen Otomatis
                </h2>
                <p className="text-sm text-gray-500 mb-6">
                  Sistem pintar ini dapat membaca file teks mentah atau teks yang disalin langsung dari PDF mesin absensi Anda.
                </p>

                <div className="space-y-6">
                  {/* Option 1: File Upload */}
                  <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                    <label className="block text-sm font-medium text-gray-700 mb-2 flex items-center gap-2">
                      <IconFileText size={16}/> Pilihan 1: Upload File Mentah (.txt / .csv)
                    </label>
                    <input 
                      type="file" 
                      accept=".txt,.csv" 
                      onChange={handleFileUpload}
                      className="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
                    />
                    <p className="text-xs text-gray-400 mt-2">Gunakan opsi ini jika Anda bisa mengekspor data mentah (CSV/TXT) dari mesin.</p>
                  </div>

                  {/* Option 2: Copy Paste */}
                  <div className="p-4 bg-gray-50 rounded-xl border border-gray-200">
                    <label className="block text-sm font-medium text-gray-700 mb-2 flex items-center gap-2">
                      <IconClipboardList size={16}/> Pilihan 2: Paste Text langsung dari PDF
                    </label>
                    <textarea 
                      value={rawText}
                      onChange={(e) => setRawText(e.target.value)}
                      placeholder="Contoh format yang dipaste: &#10;1 1 MARNI 7 PIN In 2026/04/16 08:01&#10;359 1 20 HIRJAN Jari In 2026/04/30 08:01"
                      className="w-full h-40 p-3 text-sm border-gray-300 rounded-lg bg-white border focus:ring-blue-500 focus:border-blue-500 font-mono"
                    ></textarea>
                    <p className="text-xs text-gray-400 mt-2">Buka file <b>PDF</b> Anda, tekan <b>Ctrl+A</b> lalu <b>Ctrl+C</b>, kemudian Paste (<b>Ctrl+V</b>) teksnya di kotak ini.</p>
                  </div>

                  {/* Actions */}
                  <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between pt-4 border-t border-gray-100 gap-4">
                    <label className="flex items-center gap-2 text-sm text-gray-700 cursor-pointer">
                      <input 
                        type="checkbox" 
                        checked={replaceData} 
                        onChange={(e) => setReplaceData(e.target.checked)}
                        className="rounded text-blue-600 focus:ring-blue-500"
                      />
                      Hapus data sebelumnya (Replace Tabel)
                    </label>
                    
                    <button 
                      onClick={processImport}
                      className="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 px-6 rounded-lg transition-colors shadow-sm flex items-center gap-2 w-full sm:w-auto justify-center"
                    >
                      <IconCalculator size={18}/>
                      Proses & Hitung
                    </button>
                  </div>

                  {importMessage && (
                    <div className={`p-3 rounded-lg text-sm ${importMessage.startsWith('Error') ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700'}`}>
                      {importMessage}
                    </div>
                  )}
                  
                  <div className="bg-yellow-50 text-yellow-800 p-3 rounded-lg text-sm flex gap-2">
                    <IconAlertCircle size={16} className="shrink-0 mt-0.5" />
                    <p><b>Algoritma Otomatis:</b> Sistem akan mengelompokkan jam tap masuk dan keluar di hari yang sama untuk karyawan yang sama. Jika karyawan melakukan 4x tap (pagi, sore, lembur masuk, lembur keluar), akan otomatis dipisah ke kolom lembur.</p>
                  </div>
                </div>
              </div>
            )}

            {/* --- TAB: DATA HARIAN --- */}
            {activeTab === 'harian' && (
              <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
                
                {/* Input Form */}
                <div className="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 lg:col-span-1 h-fit">
                  <h2 className="text-lg font-semibold mb-4 flex items-center gap-2">
                    <IconPlus size={18} /> Input Absen Baru
                  </h2>
                  <form onSubmit={handleAddRecord} className="space-y-4">
                    <div>
                      <label className="block text-xs font-medium text-gray-500 mb-1">Tanggal</label>
                      <input type="date" required className="w-full border-gray-300 rounded-lg p-2 text-sm bg-gray-50 border focus:ring-blue-500 focus:border-blue-500" value={formData.date} onChange={e => setFormData({...formData, date: e.target.value})} />
                    </div>
                    <div>
                      <label className="block text-xs font-medium text-gray-500 mb-1">Nama Karyawan</label>
                      <input type="text" required placeholder="Contoh: Budi" className="w-full border-gray-300 rounded-lg p-2 text-sm bg-gray-50 border focus:ring-blue-500 focus:border-blue-500" value={formData.name} onChange={e => setFormData({...formData, name: e.target.value})} />
                    </div>
                    
                    <div className="grid grid-cols-2 gap-4 pt-2 border-t border-gray-100">
                      <div>
                        <label className="block text-xs font-medium text-gray-500 mb-1">Masuk Normal</label>
                        <input type="time" required className="w-full border-gray-300 rounded-lg p-2 text-sm bg-gray-50 border" value={formData.inNormal} onChange={e => setFormData({...formData, inNormal: e.target.value})} />
                      </div>
                      <div>
                        <label className="block text-xs font-medium text-gray-500 mb-1">Keluar Normal</label>
                        <input type="time" className="w-full border-gray-300 rounded-lg p-2 text-sm bg-gray-50 border" value={formData.outNormal} onChange={e => setFormData({...formData, outNormal: e.target.value})} />
                      </div>
                    </div>

                    <div className="grid grid-cols-2 gap-4 pt-2 border-t border-gray-100">
                      <div>
                        <label className="block text-xs font-medium text-gray-500 mb-1">Masuk Lembur</label>
                        <input type="time" className="w-full border-gray-300 rounded-lg p-2 text-sm bg-gray-50 border" value={formData.inLembur} onChange={e => setFormData({...formData, inLembur: e.target.value})} />
                      </div>
                      <div>
                        <label className="block text-xs font-medium text-gray-500 mb-1">Keluar Lembur</label>
                        <input type="time" className="w-full border-gray-300 rounded-lg p-2 text-sm bg-gray-50 border" value={formData.outLembur} onChange={e => setFormData({...formData, outLembur: e.target.value})} />
                      </div>
                      <p className="col-span-2 text-xs text-gray-400 mt-1 italic">*Kosongkan jam lembur jika karyawan lanjut dari shift normal.</p>
                    </div>

                    <button type="submit" className="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors mt-4">
                      Tambah Data
                    </button>
                  </form>
                </div>

                {/* Table View */}
                <div className="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 lg:col-span-2 overflow-x-auto">
                  <h2 className="text-lg font-semibold mb-4 flex items-center gap-2">
                    <IconFileText size={18} /> Tabel Rekaman Harian
                  </h2>
                  <table className="w-full text-sm text-left whitespace-nowrap">
                    <thead className="bg-gray-50 text-gray-600 font-medium border-b border-gray-200">
                      <tr>
                        <th className="px-4 py-3 rounded-tl-lg">Tanggal</th>
                        <th className="px-4 py-3">Nama</th>
                        <th className="px-4 py-3 text-center">In</th>
                        <th className="px-4 py-3 text-center">Out</th>
                        <th className="px-4 py-3 text-center bg-blue-50 text-blue-700">Telat (Mnt)</th>
                        <th className="px-4 py-3 text-center bg-green-50 text-green-700">HK</th>
                        <th className="px-4 py-3 text-center bg-orange-50 text-orange-700">Lembur (Jam)</th>
                        <th className="px-4 py-3 rounded-tr-lg"></th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-gray-100">
                      {computedRecords.length === 0 ? (
                        <tr>
                          <td colSpan="8" className="text-center py-8 text-gray-400">Belum ada data absensi.</td>
                        </tr>
                      ) : (
                        computedRecords.map((rec) => (
                          <tr key={rec.id} className="hover:bg-gray-50 transition-colors">
                            <td className="px-4 py-3 text-gray-600">{rec.date}</td>
                            <td className="px-4 py-3 font-medium text-gray-900">{rec.name}</td>
                            <td className="px-4 py-3 text-center text-gray-600">
                              {rec.inNormal}
                              {rec.inLembur && <span className="block text-xs text-orange-500">+{rec.inLembur}</span>}
                            </td>
                            <td className="px-4 py-3 text-center text-gray-600">
                              {rec.outNormal || '-'}
                              {rec.outLembur && <span className="block text-xs text-orange-500">+{rec.outLembur}</span>}
                            </td>
                            <td className="px-4 py-3 text-center font-bold text-red-500">{rec.lateMins > 0 ? rec.lateMins : '-'}</td>
                            <td className="px-4 py-3 text-center font-bold text-green-600">{rec.hk}</td>
                            <td className="px-4 py-3 text-center font-bold text-orange-500">{rec.otHours > 0 ? rec.otHours : '-'}</td>
                            <td className="px-4 py-3 text-right">
                              <button onClick={() => handleDelete(rec.id)} className="text-red-400 hover:text-red-600 p-1">
                                <IconTrash2 size={16} />
                              </button>
                            </td>
                          </tr>
                        ))
                      )}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {/* --- TAB: REKAP GAJI --- */}
            {activeTab === 'rekap' && (
              <div className="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 overflow-x-auto">
                <div className="flex justify-between items-center mb-6">
                  <h2 className="text-lg font-semibold flex items-center gap-2">
                    <IconUsers size={18} /> Rekapitulasi Absensi Karyawan
                  </h2>
                </div>
                
                <table className="w-full text-sm text-left whitespace-nowrap">
                  <thead className="bg-gray-800 text-white font-medium border-b border-gray-200">
                    <tr>
                      <th className="px-4 py-3 rounded-tl-lg">Nama Karyawan</th>
                      <th className="px-4 py-3 text-center">Total Kehadiran</th>
                      <th className="px-4 py-3 text-center bg-green-700">Total HK</th>
                      <th className="px-4 py-3 text-center bg-orange-600">Total Lembur</th>
                      <th className="px-4 py-3 text-center bg-red-700 rounded-tr-lg">Total Telat</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-gray-100">
                    {summary.length === 0 ? (
                       <tr>
                       <td colSpan="5" className="text-center py-8 text-gray-400">Belum ada data untuk direkap.</td>
                     </tr>
                    ) : summary.map((emp) => (
                      <tr key={emp.name} className="hover:bg-gray-50">
                        <td className="px-4 py-4 font-semibold text-gray-900">{emp.name}</td>
                        <td className="px-4 py-4 text-center text-gray-600">{emp.daysPresent} Hari</td>
                        <td className="px-4 py-4 text-center font-bold text-green-600">{emp.hk} HK</td>
                        <td className="px-4 py-4 text-center font-bold text-orange-500">{emp.ot} Jam</td>
                        <td className="px-4 py-4 text-center font-bold text-red-500">{emp.late} Menit</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}

          </div>
        </div>
      );
    }

    // Render the App
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
